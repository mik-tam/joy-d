# Create a local .env file from this template. Never commit the real key.
# Production hosts commonly set PORT automatically. `npm start` binds to the
# host's network interface; local development remains loopback-only.
PORT=8787

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# World visuals: each world's sprites and backdrop are generated live from the
# AI story (roughly 4-5 low-quality images per world, a few cents total).
# OpenRouter credit is used when OPENROUTER_API_KEY is set; otherwise OpenAI.
# Set JOYD_WORLD_IMAGES=off to disable and use the painted stage kit only.
OPENAI_IMAGE_MODEL=gpt-image-1
JOYD_WORLD_IMAGES=on
# Pin which account serves stories / pays for images: openai | openrouter.
# Default for both: OpenRouter when its key exists, otherwise OpenAI.
JOYD_TEXT_PROVIDER=
JOYD_IMAGE_PROVIDER=

# Optional hackathon/demo alternative. When present, OpenRouter takes priority
# for both story generation and world images.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_IMAGE_MODEL=openai/gpt-image-1-mini
OPENROUTER_SITE_URL=http://localhost:5173

# Real anonymous smile matching (optional locally, required for production
# matching). Run supabase/migrations/20260721_create_joyd_match_profiles.sql
# in the Supabase SQL editor, then set these server-only values. Never expose
# the service-role key in a VITE_* variable.
# Use the project URL only — do NOT include /rest/v1/
# Example: https://YOUR_PROJECT_REF.supabase.co
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
